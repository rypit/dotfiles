#!/bin/bash
set -e

# Configuration
MODEL_REPO="mlx-community/Qwen3-Coder-Next-8bit"
CONTEXT_SIZE=32768
PORT=8080

# Paths
MODEL_DIR="$HOME/.local/share/llm/models"
export PATH="$HOME/.local/bin:$PATH"

mkdir -p "$MODEL_DIR"

authenticate() {
  if ! command -v hf >/dev/null 2>&1; then
    echo "❌ 'hf' CLI is not installed. Please install it to authenticate."
    exit 1
  fi

  if [ -z "${HF_TOKEN:-}" ]; then
    echo "⚠️  HF_TOKEN is not set. Falling back to interactive Hugging Face login..."
    hf auth login
    return
  fi

  echo "🔐 Authenticating with Hugging Face..."
  hf auth login --token "$HF_TOKEN"
}

setup() {
  echo "🛠️ Setting up LLM environment..."
  
  if ! command -v uv >/dev/null 2>&1; then
    echo "❌ 'uv' is not installed. Please run script/bootstrap first."
    exit 1
  fi
  
  # Install huggingface_hub for fast downloads
  uv tool install huggingface_hub --force
  # Install mlx-lm for running the model
  uv tool install mlx-lm --force
}

download() {
  authenticate
  echo "📥 Downloading $MODEL_REPO from Hugging Face..."
  hf download "$MODEL_REPO" --local-dir "$MODEL_DIR"
}

start() {
  # Check if model directory exists and has files
  if [ ! -d "$MODEL_DIR" ] || [ -z "$(ls -A "$MODEL_DIR" 2>/dev/null)" ]; then
    echo "❌ Model not found at $MODEL_DIR. Running download first..."
    download
  fi

  echo "👋 Hey there! Starting mlx-lm server on port $PORT..."
  echo "   Model: $MODEL_REPO"
  echo "   Context: $CONTEXT_SIZE"

  mlx-lm serve \
    --model "$MODEL_DIR" \
    --port "$PORT" \
    --context-size "$CONTEXT_SIZE"
}

benchmark() {
  API_BASE="http://localhost:$PORT/v1"
  API="$API_BASE/chat/completions"
  MODEL_NAME="openai/qwen3-coder-next-80b"
  ITERS=3
  MAX_TOKENS=256

  echo "🔬 Running benchmark against $API_BASE using model $MODEL_NAME"

  # Ensure server is reachable
  if ! curl -sSf "$API_BASE/models" >/dev/null 2>&1; then
    echo "❌ Local server not reachable at $API_BASE. Start it first with ./script/llm start" >&2
    return 1
  fi

  total=0
  for i in $(seq 1 $ITERS); do
    echo "- Iteration $i/$ITERS: requesting $MAX_TOKENS tokens..."
    start_time=$(date +%s.%N)
    curl -s -X POST "$API" -H "Content-Type: application/json" -d "{\"model\":\"$MODEL_NAME\",\"messages\":[{\"role\":\"user\",\"content\":\"Generate plain text of approximately $MAX_TOKENS tokens without code blocks or commentary.\"}],\"max_tokens\":$MAX_TOKENS}" >/dev/null 2>&1
    end_time=$(date +%s.%N)
    dt=$(echo "$end_time - $start_time" | bc -l)
    if [ "$(echo "$dt <= 0" | bc -l)" -eq 1 ]; then dt=0.001; fi
    tps=$(echo "scale=2; $MAX_TOKENS / $dt" | bc -l)
    echo "  -> ${tps} tokens/sec (elapsed ${dt}s)"
    total=$(echo "$total + $tps" | bc -l)
  done

  avg=$(echo "scale=2; $total / $ITERS" | bc -l)
  echo "✅ Benchmark complete — average ${avg} tokens/sec over ${ITERS} runs"
}

usage() {
  echo "Usage: $0 {setup|download|start}"
  exit 1
}

case "$1" in
  setup)
    setup
    ;;
  download)
    download
    ;;
  benchmark)
    benchmark
    ;;
  start)
    start
    ;;
  *)
    usage
    ;;
esac
