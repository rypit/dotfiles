#!/bin/bash
set -e

# This script sets up the development environment.
if [ "$1" == "--debug" ]; then
  set -x
fi

DIR="$(cd "$(dirname "$0")/../" && pwd)"
BREWFILE="$DIR/Brewfile"

# Install Homebrew if missing
install_homebrew() {
  if ! command -v brew >/dev/null 2>&1; then
    echo "🍺 Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi
}

# Run brew_bundle
run_brew_bundle() {
  echo "📦 Running brew bundle..."

  local bundle_file="$BREWFILE"

  if [ "$CI" = "true" ]; then
    echo "⚠️ CI detected: Generating a temporary MAS-free Brewfile..."
    bundle_file="$(mktemp)"
    # Create a copy of the Brewfile without any lines starting with 'mas'
    grep -v '^mas ' "$BREWFILE" > "$bundle_file"
  fi

  brew bundle --file="$bundle_file"

  # Clean up temporary file
  if [ "$CI" = "true" ]; then
    rm "$bundle_file"
  fi
}

# Install .zshrc and .zsh_plugins.txt
install_zsh_config() {
  echo "👨🏻‍💻 Installing Zsh configuration..."
  ln -sf "$DIR/config/.zshrc" "$HOME/.zshrc"
  ln -sf "$DIR/config/.zsh_plugins.txt" "$HOME/.zsh_plugins.txt"
  if [ -f "$DIR/config/.p10k.zsh" ]; then
    ln -sf "$DIR/config/.p10k.zsh" "$HOME/.p10k.zsh"
  fi
  if [ -f "$DIR/config/.aider.conf.yml" ]; then
    ln -sf "$DIR/config/.aider.conf.yml" "$HOME/.aider.conf.yml"
  fi
}

# Configure shell to zsh
configure_shell() {
  if [ "$CI" = "true" ]; then
    echo "🐚 Skipping interactive shell configuration in CI..."
    return
  fi
  echo "🐚 Configuring shell to zsh..."
  ZSH_PATH="$(command -v zsh)"
  if [ -n "$ZSH_PATH" ] && [ "$SHELL" != "$ZSH_PATH" ]; then
    chsh -s "$ZSH_PATH"
  fi
}

# Use .gitignore_global from dotfiles
install_gitignore() {
  echo "⚙️ Configuring git..."
  ln -sf "$DIR/config/.gitignore_global" "$HOME/.gitignore_global"
  git config --global core.excludesfile "$HOME/.gitignore_global"
  git config --global push.default current
}

# Install Ghostty config
install_ghostty_config() {
  echo "🖥️ Installing Ghostty configuration..."
  mkdir -p "$HOME/.config/ghostty"
  ln -sf "$DIR/config/.ghostty" "$HOME/.config/ghostty/config"
}

configure_macOS() {
  if [ "$(uname)" == "Darwin" ]; then
    echo "🍏 Configuring macOS..."
    bash "$DIR/script/macos"
  fi
}

setup_llm() {
  if [ "$CI" = "true" ]; then
    echo "🤖 Skipping Local LLM setup in CI..."
    return
  fi
  echo "🤖 Setting up Local LLM..."
  bash "$DIR/script/llm" setup
}

partytime() {
  echo -e "\n🤙 All set! Fire up a new shell and let's roll!"
}

# Do the things...
install_homebrew
run_brew_bundle
configure_shell
install_zsh_config
install_gitignore
install_ghostty_config
configure_macOS
setup_llm

partytime
